# Server Environment Variables Configuration Example
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_token_here

# MongoDB Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-medical?retryWrites=true&w=majority

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Client URL (Origin)
CLIENT_URL=http://localhost:5173

# Admin Initial Credentials Setup (Used by npm run seed)
ADMIN_EMAIL=admin@medivoice.com
ADMIN_PASSWORD=your_secure_admin_password
